st.caption("Exact score = 3 pts · correct winner or draw = 1 pt · highest total takes the pot.")

data = load_data()
matches = all_matches(data)
results = data.get("results", {})

tab_picks, tab_table, tab_org, tab_how = st.tabs(
    ["⚽ My picks", "🏆 Table", "🔐 Organizer", "💰 How it works"]
)

# ───────────── MY PICKS ─────────────
with tab_picks:
    name = st.text_input("Your name", key="player_name", placeholder="e.g. Shakiba").strip()

    if name:
        existing = data["players"].get(name, {}).get("picks", {})
        st.caption(
            f"Type each score like **2-1** (first team first). "
            f"Leave blank to skip a match. Picks lock once the real result is in."
        )

        inputs = {}
        for m in matches:
            res = results.get(m["id"])
            pick = existing.get(m["id"])
            left, right = st.columns([3, 1])
            with left:
                st.markdown(
                    f'<span class="match-date">{m["d"].upper()}</span><br>'
                    f'**{m["h"]}** vs **{m["a"]}**',
                    unsafe_allow_html=True,
                )
            with right:
                if res:  # locked
                    p = points_for(pick, res)
                    badge = (
                        '<span class="pts-exact">EXACT +3</span>' if p == 3
                        else '<span class="pts-result">+1</span>' if p == 1
                        else '<span class="pts-zero">0</span>' if p == 0
                        else ""
                    )
                    shown = f"{pick[0]}-{pick[1]}" if pick else "no pick"
                    st.markdown(
                        f"🔒 you: **{shown}**<br>final: **{res[0]}-{res[1]}** {badge}",
                        unsafe_allow_html=True,
                    )
                else:
                    default = f"{pick[0]}-{pick[1]}" if pick else ""
                    inputs[m["id"]] = st.text_input(
                        "score", value=default, key=f"pick_{m['id']}",
                        placeholder="2-1", label_visibility="collapsed",
                    )
            st.markdown("<hr>", unsafe_allow_html=True)

        if st.button("💾 Save my picks", use_container_width=True):
            fresh = load_data()  # re-read so we don't clobber others
            picks = dict(fresh["players"].get(name, {}).get("picks", {}))
            bad = []
            for mid, text in inputs.items():
                if not text.strip():
                    continue
                parsed = parse_score(text)
                if parsed:
                    picks[mid] = parsed
                else:
                    bad.append(text)
            fresh["players"][name] = {"picks": picks}
            save_data(fresh)
            if bad:
                st.warning(f"Saved, but I skipped these (use 2-1 format): {', '.join(bad)}")
            else:
                st.success(f"Saved {len(picks)} picks for {name} ✓")
            st.rerun()
    else:
        st.info("Enter your name to make picks.")

# ───────────── TABLE ─────────────
with tab_table:
    board = sorted(
        (
            (pname, *totals(p.get("picks", {}), results, matches))
            for pname, p in data["players"].items()
        ),
        key=lambda r: (-r[1], -r[2], r[0].lower()),
    )
    if not board:
        st.info("No players yet — save your picks to appear here.")
    for i, (pname, pts, exact) in enumerate(board, start=1):
        medal = "🥇" if i == 1 else "🥈" if i == 2 else "🥉" if i == 3 else f"{i}."
        c1, c2, c3 = st.columns([6, 2, 2])
        c1.markdown(f"{medal} **{pname}**")
        c2.markdown(f"<span style='color:#8CA394'>{exact} exact</span>", unsafe_allow_html=True)
        c3.markdown(
            f"<span style='font-family:Anton;font-size:22px;color:#E2A93B'>{pts}</span>",
            unsafe_allow_html=True,
        )

# ───────────── ORGANIZER ─────────────
with tab_org:
    pin = st.text_input("Organizer PIN", type="password")
    if pin == ORGANIZER_PIN:
        st.success("Organizer mode unlocked")

        st.subheader("Enter final scores")
        st.caption("Type the real score (e.g. 2-1) and save. This locks picks and updates the table.")
        res_inputs = {}
        for m in matches:
            cur = results.get(m["id"])
            left, right = st.columns([3, 1])
            left.markdown(f'<span class="match-date">{m["d"].upper()}</span><br>'
                          f'**{m["h"]}** vs **{m["a"]}**', unsafe_allow_html=True)
            res_inputs[m["id"]] = right.text_input(
                "final", value=f"{cur[0]}-{cur[1]}" if cur else "",
                key=f"res_{m['id']}", placeholder="2-1", label_visibility="collapsed",
            )
        if st.button("💾 Save final scores", use_container_width=True):
            fresh = load_data()
            new_results = dict(fresh.get("results", {}))
            for mid, text in res_inputs.items():
                parsed = parse_score(text)
                if parsed:
                    new_results[mid] = parsed
                elif not text.strip() and mid in new_results:
                    del new_results[mid]  # cleared
            fresh["results"] = new_results
            save_data(fresh)
            st.success("Results saved ✓")
            st.rerun()

        st.divider()
        st.subheader("Add a match (knockout rounds)")
        c1, c2 = st.columns(2)
        t1 = c1.text_input("Team 1", placeholder="Brazil")
        t2 = c2.text_input("Team 2", placeholder="France")
        label = st.text_input("Round / date label", placeholder="Round of 32 · Jun 29")
        if st.button("➕ Add match to the pool"):
            if t1.strip() and t2.strip():
                fresh = load_data()
                fresh.setdefault("matches", []).append({
                    "id": f"c{len(fresh.get('matches', [])) + 1:03d}",
                    "d": label.strip() or "Knockout round",
                    "h": t1.strip(), "a": t2.strip(),
                })
                save_data(fresh)
                st.success(f"Added {t1.strip()} vs {t2.strip()} ✓")
                st.rerun()
            else:
                st.warning("Enter both team names.")

        st.divider()
        st.subheader("Backup & restore")
        st.caption(
            "Streamlit's free hosting can reset the app's files when it restarts. "
            "Download a backup after every round of results — it takes one tap."
        )
        st.download_button(
            "⬇️ Download pool backup",
            data=json.dumps(load_data()),
            file_name="pool_backup.json",
            mime="application/json",
            use_container_width=True,
        )
        up = st.file_uploader("Restore from backup", type="json")
        if up is not None and st.button("♻️ Restore this backup"):
            try:
                restored = json.load(up)
                assert "players" in restored and "results" in restored
                save_data(restored)
                st.success("Pool restored ✓")
                st.rerun()
            except Exception:
                st.error("That file doesn't look like a pool backup.")
    elif pin:
        st.error("Wrong PIN.")

