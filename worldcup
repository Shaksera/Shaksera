SCORE_RE = re.compile(r"^\s*(\d{1,2})\s*[-:]\s*(\d{1,2})\s*$")


# ───────────── data layer ─────────────
def load_data():
    if os.path.exists(DATA_FILE):
        try:
            with open(DATA_FILE) as f:
                return json.load(f)
        except Exception:
            pass
    return {"players": {}, "results": {}, "matches": []}


def save_data(data):
    with _lock:
        with open(DATA_FILE, "w") as f:
            json.dump(data, f)


def all_matches(data):
    return MATCHES + data.get("matches", [])


def parse_score(text):
    m = SCORE_RE.match(text or "")
    return [int(m.group(1)), int(m.group(2))] if m else None


def points_for(pick, res):
    if not pick or not res:
        return None
    if pick == res:
        return 3
    out = lambda s: "H" if s[0] > s[1] else ("A" if s[0] < s[1] else "D")
    return 1 if out(pick) == out(res) else 0


def totals(picks, results, matches):
    pts, exact = 0, 0
    for m in matches:
        p = points_for(picks.get(m["id"]), results.get(m["id"]))
        if p == 3:
            exact += 1
        if p:
            pts += p
    return pts, exact


